# Dependencies
node_modules/

# Compiled output (source .js files like cucumber.js, test-runner.js and the
# dashboard are tracked; compiled output only ever lands in dist/)
dist/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.*.local

# Test reports and logs
reports/
*.log
logs/

# IDE and editor files (.vscode is tracked — it holds the shared debug configs)
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Playwright
.auth/
