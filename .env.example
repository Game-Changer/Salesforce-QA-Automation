# Shared QA Automation User for both local testing and CI/CD
# Local: Fill .env from your team's shared QA user credentials
# CI/CD: Same credentials are stored as GitHub repository secrets

SF_USERNAME=qa-automation@salesforce-poc.com
SF_PASSWORD=your_password_here
SF_SECURITY_TOKEN=your_security_token_here

# Salesforce Org URL
SF_LOGIN_URL=https://orgfarm-a0b0258612-dev-ed.develop.my.salesforce.com

# Playwright Configuration
HEADED=false
DEBUG=false

# Browser Settings
BROWSER=chromium
TIMEOUT=30000

# Logging
LOG_LEVEL=info
